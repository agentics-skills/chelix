# Copy to .envrc and fill in your values, then run `direnv allow`.
# Variables use the CHELIX_<SECTION>__<FIELD> override convention
# which maps directly to chelix.toml config sections.

# ── Identity (skip onboarding name prompts) ──────────────────────
export CHELIX_IDENTITY__NAME="chelix"          # bot display name
export CHELIX_IDENTITY__EMOJI=""               # bot emoji
export CHELIX_USER__NAME=""                    # your name

